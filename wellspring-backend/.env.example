# --- Database ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wellspring

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- LLM providers for chat replies, tried in this order: groq, anthropic,
# openai. GROQ_API_KEY is the one that matters — Anthropic/OpenAI are
# optional extra fallbacks, not required. Get a Groq key at console.groq.com
# (free tier, no credit card).
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — override if the default model gets deprecated (Groq retires
# models often; check with:
#   curl https://api.groq.com/openai/v1/models -H "Authorization: Bearer YOUR_KEY")
GROQ_CHAT_MODEL=openai/gpt-oss-20b

# --- Embeddings — also Groq, via its OpenAI-compatible /embeddings
# endpoint. Requires the same GROQ_API_KEY above, nothing separate. ---
EMBEDDING_MODEL=nomic-embed-text-v1_5
EMBEDDING_DIMENSIONS=768          # nomic-embed-text-v1_5's native output size — must match scripts/createVectorIndex.js

# --- Server ---
PORT=4000
NODE_ENV=development
